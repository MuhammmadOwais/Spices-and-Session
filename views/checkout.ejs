<%- include('partials/header') %>

<section class="checkout-page-section container">
  <div class="section-header">
    <h1>Secure Checkout</h1>
    <p>Please enter your shipping address and payment details below to complete your order.</p>
  </div>
  
  <div class="checkout-page-layout">
    
    <!-- Left Column: Shipping & Billing Form -->
    <div class="checkout-form-column">
      <form action="/checkout" method="POST" class="checkout-billing-form" id="checkout-main-form">
        
        <!-- Contact Block -->
        <div class="form-section-block">
          <h3>Contact Information</h3>
          <div class="form-grid-2">
            <div class="form-field">
              <label for="email">Email Address *</label>
              <input type="email" id="email" name="email" required placeholder="you@example.com">
            </div>
            <div class="form-field">
              <label for="phone">Phone Number *</label>
              <input type="tel" id="phone" name="phone" required placeholder="(555) 000-0000">
            </div>
          </div>
        </div>

        <!-- Shipping Address Block -->
        <div class="form-section-block">
          <h3>Shipping Address</h3>
          <div class="form-field">
            <label for="name">Recipient Name *</label>
            <input type="text" id="name" name="name" required placeholder="Jane Doe">
          </div>
          <div class="form-field">
            <label for="address">Street Address *</label>
            <input type="text" id="address" name="address" required placeholder="123 Main St, Apt 4B">
          </div>
          <div class="form-grid-3">
            <div class="form-field">
              <label for="city">City *</label>
              <input type="text" id="city" name="city" required placeholder="Seattle">
            </div>
            <div class="form-field">
              <label for="state">State *</label>
              <input type="text" id="state" name="state" required placeholder="WA">
            </div>
            <div class="form-field">
              <label for="zip">ZIP / Postal Code *</label>
              <input type="text" id="zip" name="zip" required placeholder="98101">
            </div>
          </div>
        </div>

        <!-- Mock Payment Block -->
        <div class="form-section-block">
          <h3>Mock Payment Details</h3>
          <p class="mock-alert-note"><i class="fa-solid fa-circle-info"></i> This is a simulation checkout. You can enter any mock card credentials.</p>
          
          <div class="form-field">
            <label for="cardName">Name on Card *</label>
            <input type="text" id="cardName" name="cardName" required placeholder="JANE DOE">
          </div>
          <div class="form-field">
            <label for="cardNumber">Credit Card Number *</label>
            <div class="credit-card-input-wrapper">
              <input type="text" id="cardNumber" name="cardNumber" required placeholder="4111 2222 3333 4444" pattern="[0-9\\s]{13,19}">
              <i class="fa-regular fa-credit-card card-input-icon"></i>
            </div>
          </div>
          <div class="form-grid-2">
            <div class="form-field">
              <label for="cardExpiry">Expiration Date *</label>
              <input type="text" id="cardExpiry" name="cardExpiry" required placeholder="MM/YY">
            </div>
            <div class="form-field">
              <label for="cardCvv">Security Code (CVV) *</label>
              <input type="password" id="cardCvv" name="cardCvv" required placeholder="123" maxlength="4">
            </div>
          </div>
        </div>

        <button type="submit" class="btn btn-primary btn-large btn-full checkout-submit-btn">
          <i class="fa-solid fa-lock"></i> Authorize & Place Mock Order
        </button>

      </form>
    </div>
    
    <!-- Right Column: Cart Drawer Review -->
    <div class="checkout-review-column">
      <div class="review-summary-card">
        <h3>Order Items</h3>
        <hr class="summary-divider">
        
        <!-- Cart Items list -->
        <div class="checkout-items-list" id="checkout-items-list">
          <!-- Injected dynamically by client-side cart.js -->
        </div>
        
        <hr class="summary-divider">
        
        <div class="summary-row">
          <span>Subtotal</span>
          <span id="checkout-subtotal">$0.00</span>
        </div>
        <div class="summary-row">
          <span>Shipping (Ground)</span>
          <span id="checkout-shipping">FREE</span>
        </div>
        <div class="summary-row">
          <span>Estimated Taxes</span>
          <span id="checkout-tax">$0.00</span>
        </div>
        
        <hr class="summary-divider">
        
        <div class="summary-row total-row">
          <span>Total</span>
          <strong id="checkout-total">$0.00</strong>
        </div>
      </div>
    </div>
    
  </div>
</section>

<%- include('partials/footer') %>
