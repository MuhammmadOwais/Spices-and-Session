<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  
  <!,  Premium Google Fonts , >
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400..900;1,400..900&family=Plus+Jakarta+Sans:ital,wght@0,200..800;1,200..800&display=swap" rel="stylesheet">
  
  <!,  FontAwesome Icons , >
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
  
  <!-- Main Stylesheet -->
  <link rel="stylesheet" href="/css/style.css?v=1.0.3">
  
  <!,  Custom Favicon , >
  <link rel="icon" type="image/png" href="https://res.cloudinary.com/dawp1fcci/image/upload/f_auto,q_auto/v1784166642/Gemini_Generated_Image_qvj3uyqvj3uyqvj3-removebg-preview_bwdmdg.png">
  
  <% if (path.startsWith('/admin')) { %>
    <!,  Admin Specific Stylesheet , >
    <link rel="stylesheet" href="/css/admin.css">
  <% } %>
</head>
<body>

  <!,  Announcement Bar , >
  <div class="announcement-bar">
    <span>Trusted by Taste | Original & Authentic Spices</span>
  </div>

  <!,  Header Navigation , >
  <header class="main-header">
    <div class="header-container">
      
      <!,  Brand Logo , >
      <a href="/" class="brand-logo">
        <img src="https://res.cloudinary.com/dawp1fcci/image/upload/f_auto,q_auto/v1784224291/Gemini_Generated_Image_hzg0z3hzg0z3hzg0-removebg-preview_kmaz3m.png" alt="Spicery Co." class="brand-logo-img">
      </a>

      <!,  Desktop Nav Menu , >
      <nav class="desktop-nav">
        <ul>
          <li><a href="/" class="<%= path === '/' ? 'active' : '' %>">Home</a></li>
          <li><a href="/products" class="<%= path.startsWith('/products') ? 'active' : '' %>">Shop</a></li>
          <li><a href="/recipes" class="<%= path.startsWith('/recipes') ? 'active' : '' %>">Recipes</a></li>
          <li><a href="/blogs" class="<%= path.startsWith('/blogs') ? 'active' : '' %>">Journal</a></li>
          <li><a href="/about" class="<%= path === '/about' ? 'active' : '' %>">About Us</a></li>
          
           <% if (userEmail) { %>
             <li><span class="user-greeting-nav"><i class="fa-solid fa-circle-user"></i> <%= userEmail.split('@')[0] %></span></li>
             <li><a href="/logout" class="user-logout-link" title="Sign Out"><i class="fa-solid fa-power-off"></i></a></li>
           <% } else { %>
             <li><a href="/login" class="<%= path === '/login' ? 'active' : '' %>">Sign In</a></li>
             <li><a href="/signup" class="user-signup-btn">Join</a></li>
           <% } %>
           
           <% if (isAdminUser) { %>
             <li><a href="/admin" class="admin-link-btn">Admin</a></li>
             <li><a href="/admin/logout" class="admin-logout-btn" title="Admin Logout"><i class="fa-solid fa-right-from-bracket"></i></a></li>
           <% } %>
        </ul>
      </nav>

      <!-- Header Search Bar (Desktop) -->
      <div class="header-search-box">
        <div class="header-search-input-wrapper">
          <i class="fa-solid fa-magnifying-glass header-search-icon"></i>
          <input type="text" id="header-search-input" placeholder="Search spices, recipes..." autocomplete="off">
        </div>
        <div id="header-search-results" class="header-search-results"></div>
      </div>

      <!-- Mobile Toggle Utilities -->
      <div class="header-utilities">
        <button id="mobile-menu-toggle" class="mobile-toggle" aria-label="Toggle Menu">
          <i class="fa-solid fa-bars"></i>
        </button>
      </div>

    </div>
  </header>

  <!,  Mobile Drawer Menu , >
  <div class="mobile-drawer" id="mobile-drawer">
    <div class="drawer-header">
      <div class="brand-logo">
        <img src="https://res.cloudinary.com/dawp1fcci/image/upload/f_auto,q_auto/v1784224291/Gemini_Generated_Image_hzg0z3hzg0z3hzg0-removebg-preview_kmaz3m.png" alt="Spicery Co." class="brand-logo-img">
      </div>
      <button class="drawer-close" id="mobile-drawer-close"><i class="fa-solid fa-xmark"></i></button>
    </div>
    <div class="drawer-content">
      <!-- Mobile Drawer Search Bar -->
      <div class="mobile-search-box">
        <div class="header-search-input-wrapper">
          <i class="fa-solid fa-magnifying-glass header-search-icon"></i>
          <input type="text" id="mobile-search-input" placeholder="Search spices..." autocomplete="off">
        </div>
        <div id="mobile-search-results" class="header-search-results"></div>
      </div>
      <nav class="mobile-nav">
        <ul>
          <li><a href="/" class="<%= path === '/' ? 'active' : '' %>">Home</a></li>
          <li><a href="/products" class="<%= path.startsWith('/products') ? 'active' : '' %>">Shop Spices</a></li>
          <li><a href="/recipes" class="<%= path.startsWith('/recipes') ? 'active' : '' %>">Recipes</a></li>
          <li><a href="/blogs" class="<%= path.startsWith('/blogs') ? 'active' : '' %>">Culinary Journal</a></li>
          <li><a href="/about" class="<%= path === '/about' ? 'active' : '' %>">About Us</a></li>
          
           <hr class="mobile-nav-divider">
           <% if (userEmail) { %>
             <li class="mobile-drawer-user-info"><span class="mobile-user-greeting"><i class="fa-solid fa-circle-user"></i> <%= userEmail %></span></li>
             <li><a href="/logout" class="mobile-admin-logout">Sign Out</a></li>
           <% } else { %>
             <li><a href="/login" class="mobile-admin-link">Sign In</a></li>
             <li><a href="/signup" class="mobile-admin-link">Create Account</a></li>
           <% } %>
           
           <% if (isAdminUser) { %>
             <hr class="mobile-nav-divider">
             <li><a href="/admin" class="mobile-admin-link">Admin Dashboard</a></li>
             <li><a href="/admin/logout" class="mobile-admin-logout">Admin Logout</a></li>
           <% } %>
        </ul>
      </nav>
    </div>
  </div>



  
  <!,  Screen Overlay (used for sidebar and mobile drawer) , >
  <div class="site-overlay" id="site-overlay"></div>
  
  <main class="page-main-content">
