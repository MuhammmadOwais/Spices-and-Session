<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  
  <!,  Premium Google Fonts , >
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400..900;1,400..900&family=Plus+Jakarta+Sans:ital,wght@0,200..800;1,200..800&display=swap" rel="stylesheet">
  
  <!,  FontAwesome Icons , >
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
  
  <!-- Main Stylesheet -->
  <link rel="stylesheet" href="/css/style.css?v=1.1.4">
  
  <!,  Custom Favicon , >
  <link rel="icon" type="image/png" href="https://res.cloudinary.com/dawp1fcci/image/upload/f_auto,q_auto/v1784166642/Gemini_Generated_Image_qvj3uyqvj3uyqvj3-removebg-preview_bwdmdg.png">
  
  <% if (path.startsWith('/admin')) { %>
    <!,  Admin Specific Stylesheet , >
    <link rel="stylesheet" href="/css/admin.css">
  <% } %>
</head>
<body>

  <!,  Announcement Bar , >
  <div class="announcement-bar">
    <span>Trusted by Taste | Original & Authentic Spices</span>
  </div>

  <!,  Header Navigation , >
  <header class="main-header">
    <div class="header-container">
      
      <!,  Brand Logo , >
      <a href="/" class="brand-logo">
        <img src="https://res.cloudinary.com/dawp1fcci/image/upload/f_auto,q_auto/v1784224291/Gemini_Generated_Image_hzg0z3hzg0z3hzg0-removebg-preview_kmaz3m.png" alt="Spicery Co." class="brand-logo-img">
      </a>

      <!-- Desktop Nav Menu -->
      <nav class="desktop-nav">
        <ul>
          <li><a href="/" class="<%= path === '/' ? 'active' : '' %>">Home</a></li>
          <li class="has-megamenu">
            <a href="/products" class="<%= path.startsWith('/products') ? 'active' : '' %>">Shop <i class="fa-solid fa-chevron-down nav-chevron" style="font-size: 0.7rem; margin-left: 0.3rem;"></i></a>
            <div class="megamenu-panel">
              <div class="megamenu-container">
                
                <div class="megamenu-column">
                  <h3>Spices & Herbs</h3>
                  <ul>
                    <li><a href="/products?category=Spices %26 Whole Seeds">Spices & Whole Seeds</a></li>
                    <li><a href="/products?category=Herbs %26 Seasonings">Herbs & Seasonings</a></li>
                  </ul>
                </div>
                
                <div class="megamenu-column">
                  <h3>Salts & Peppers</h3>
                  <ul>
                    <li><a href="/products?category=Salts %26 Peppercorns">Salts & Peppercorns</a></li>
                    <li><a href="/products?category=Dried Chilis %26 Paprika">Dried Chilis & Paprika</a></li>
                  </ul>
                </div>
                
                <div class="megamenu-column">
                  <h3>Baking & Sweeteners</h3>
                  <ul>
                    <li><a href="/products?category=Baking, Vanilla %26 Sweeteners">Baking, Vanilla & Sweeteners</a></li>
                  </ul>
                </div>
                
                <div class="megamenu-column">
                  <h3>Pantry & Teas</h3>
                  <ul>
                    <li><a href="/products?category=Dried Vegetables %26 Mushrooms">Dried Vegetables & Mushrooms</a></li>
                    <li><a href="/products?category=Specialty Powders %26 Flavors">Specialty Powders & Flavors</a></li>
                    <li><a href="/products?category=Beverages">Beverages</a></li>
                  </ul>
                </div>

              </div>
            </div>
          </li>
          <li><a href="/recipes" class="<%= path.startsWith('/recipes') ? 'active' : '' %>">Recipes</a></li>
          <li><a href="/blogs" class="<%= path.startsWith('/blogs') ? 'active' : '' %>">Journal</a></li>
          <li><a href="/about" class="<%= path === '/about' ? 'active' : '' %>">About Us</a></li>
          <li><a href="/contact" class="<%= path === '/contact' ? 'active' : '' %>">Contact</a></li>
          
           <% if (isAdminUser) { %>
             <li><a href="/admin" class="admin-link-btn">Admin</a></li>
             <li><a href="/admin/logout" class="admin-logout-btn" title="Admin Logout"><i class="fa-solid fa-right-from-bracket"></i></a></li>
           <% } %>
        </ul>
      </nav>

      <!-- Header Search Bar & User Actions (Desktop) -->
      <div class="header-right-group">
        <div class="header-search-box">
          <div class="header-search-input-wrapper">
            <i class="fa-solid fa-magnifying-glass header-search-icon"></i>
            <input type="text" id="header-search-input" placeholder="Search spices, recipes..." autocomplete="off">
          </div>
          <div id="header-search-results" class="header-search-results"></div>
        </div>

        <div class="header-user-actions">
          <% if (userEmail) { %>
            <span class="user-greeting-nav"><i class="fa-solid fa-circle-user"></i> <%= userEmail.split('@')[0] %></span>
            <a href="/logout" class="user-logout-link" title="Sign Out"><i class="fa-solid fa-power-off"></i></a>
          <% } else { %>
            <a href="/login" class="nav-signin-link <%= path === '/login' ? 'active' : '' %>">Sign In</a>
            <a href="/signup" class="user-signup-btn">Join</a>
          <% } %>
        </div>
      </div>

      <!-- Mobile Toggle Utilities -->
      <div class="header-utilities">
        <button id="mobile-menu-toggle" class="mobile-toggle" aria-label="Toggle Menu">
          <i class="fa-solid fa-bars"></i>
        </button>
      </div>

    </div>
  </header>

  <!-- Mobile Drawer Menu -->
  <div class="mobile-drawer" id="mobile-drawer">
    <div class="drawer-header">
      <div class="brand-logo">
        <img src="https://res.cloudinary.com/dawp1fcci/image/upload/f_auto,q_auto/v1784224291/Gemini_Generated_Image_hzg0z3hzg0z3hzg0-removebg-preview_kmaz3m.png" alt="Spicery Co." class="brand-logo-img">
      </div>
      <button class="drawer-close" id="mobile-drawer-close"><i class="fa-solid fa-xmark"></i></button>
    </div>
    <div class="drawer-content">
      
      <!-- 1. Pages Navigation Menu -->
      <nav class="mobile-nav" style="margin-bottom: 2rem;">
        <ul>
          <li><a href="/" class="<%= path === '/' ? 'active' : '' %>">Home</a></li>
          <li class="mobile-has-subnav">
            <a href="/products" class="<%= path.startsWith('/products') ? 'active' : '' %>">Shop Spices <i class="fa-solid fa-chevron-down" style="font-size: 0.8rem; margin-left: 0.4rem;"></i></a>
            <ul class="mobile-subnav" style="padding-left: 1.2rem; margin-top: 0.5rem; display: flex; flex-direction: column; gap: 0.8rem; font-size: 0.95rem;">
              <li><a href="/products?category=Spices %26 Whole Seeds" style="text-transform: none; font-weight: 500;">Spices & Whole Seeds</a></li>
              <li><a href="/products?category=Herbs %26 Seasonings" style="text-transform: none; font-weight: 500;">Herbs & Seasonings</a></li>
              <li><a href="/products?category=Salts %26 Peppercorns" style="text-transform: none; font-weight: 500;">Salts & Peppercorns</a></li>
              <li><a href="/products?category=Dried Chilis %26 Paprika" style="text-transform: none; font-weight: 500;">Dried Chilis & Paprika</a></li>
              <li><a href="/products?category=Baking, Vanilla %26 Sweeteners" style="text-transform: none; font-weight: 500;">Baking & Sweeteners</a></li>
              <li><a href="/products?category=Dried Vegetables %26 Mushrooms" style="text-transform: none; font-weight: 500;">Dried Vegetables & Mushrooms</a></li>
              <li><a href="/products?category=Specialty Powders %26 Flavors" style="text-transform: none; font-weight: 500;">Specialty Powders & Flavors</a></li>
              <li><a href="/products?category=Beverages" style="text-transform: none; font-weight: 500;">Beverages / Teas</a></li>
            </ul>
          </li>
          <li><a href="/recipes" class="<%= path.startsWith('/recipes') ? 'active' : '' %>">Recipes</a></li>
          <li><a href="/blogs" class="<%= path.startsWith('/blogs') ? 'active' : '' %>">Culinary Journal</a></li>
          <li><a href="/about" class="<%= path === '/about' ? 'active' : '' %>">About Us</a></li>
        </ul>
      </nav>

      <!-- 2. Search Bar -->
      <div class="mobile-search-box" style="margin-bottom: 2rem; padding: 0; background: none; border-bottom: none;">
        <div class="header-search-input-wrapper">
          <i class="fa-solid fa-magnifying-glass header-search-icon"></i>
          <input type="text" id="mobile-search-input" placeholder="Search spices..." autocomplete="off">
        </div>
        <div id="mobile-search-results" class="header-search-results"></div>
      </div>

      <!-- 3. Contact Page Button -->
      <div class="mobile-contact-wrapper" style="margin-bottom: 2rem;">
        <a href="/contact" class="btn btn-secondary <%= path === '/contact' ? 'active' : '' %>" style="display: block; text-align: center; font-weight: 750; text-transform: uppercase; font-size: 0.85rem; letter-spacing: 0.08em; padding: 0.9rem;">Contact Us</a>
      </div>

      <!-- 4. Sign In & Sign Up Buttons (One Line) -->
      <div class="mobile-auth-row" style="display: flex; gap: 1rem; align-items: center; border-top: 1px solid var(--color-border); padding-top: 1.5rem;">
        <% if (userEmail) { %>
          <span class="mobile-user-greeting" style="font-size: 0.9rem; font-weight: 600; color: var(--color-primary); flex-grow: 1; text-overflow: ellipsis; overflow: hidden; white-space: nowrap;"><i class="fa-solid fa-circle-user"></i> <%= userEmail.split('@')[0] %></span>
          <a href="/logout" class="btn btn-outline" style="padding: 0.6rem 1.2rem; font-size: 0.8rem; font-weight: 700; text-transform: uppercase; border: 1px solid var(--color-border); border-radius: var(--border-radius);">Sign Out</a>
        <% } else { %>
          <a href="/login" class="btn btn-outline" style="flex: 1; text-align: center; padding: 0.8rem; font-size: 0.82rem; font-weight: 750; text-transform: uppercase; letter-spacing: 0.05em; border: 1px solid var(--color-primary); border-radius: var(--border-radius); color: var(--color-primary);">Sign In</a>
          <a href="/signup" class="btn btn-primary" style="flex: 1; text-align: center; padding: 0.8rem; font-size: 0.82rem; font-weight: 750; text-transform: uppercase; letter-spacing: 0.05em; border-radius: var(--border-radius); color: #000000;">Join Us</a>
        <% } %>
      </div>

      <% if (isAdminUser) { %>
        <div class="mobile-admin-actions" style="margin-top: 1.5rem; border-top: 1px dashed var(--color-border); padding-top: 1rem;">
          <a href="/admin" class="mobile-admin-link" style="display: block; margin-bottom: 0.8rem; font-weight: 700; font-size: 0.9rem; color: var(--color-accent-terracotta);">Admin Dashboard</a>
          <a href="/admin/logout" class="mobile-admin-logout" style="display: block; font-weight: 700; font-size: 0.9rem; color: #cc3333;">Admin Logout</a>
        </div>
      <% } %>

    </div>
  </div>



  
  <!,  Screen Overlay (used for sidebar and mobile drawer) , >
  <div class="site-overlay" id="site-overlay"></div>
  
  <main class="page-main-content">
