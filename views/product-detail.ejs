<%- include('partials/header') %>

<!-- Breadcrumbs navigation -->
<div class="breadcrumbs-nav container">
  <a href="/">Home</a>
  <span class="separator"><i class="fa-solid fa-chevron-right"></i></span>
  <a href="/products">Shop</a>
  <span class="separator"><i class="fa-solid fa-chevron-right"></i></span>
  <a href="/products?category=<%= product.category %>" class="capitalize-text"><%= product.category %></a>
  <span class="separator"><i class="fa-solid fa-chevron-right"></i></span>
  <span class="current"><%= product.name %></span>
</div>

<!-- Product Detail Showcase -->
<section class="product-detail-showcase container">
  <div class="detail-layout">
    
    <!-- Gallery Column -->
    <div class="detail-gallery">
      <div class="main-image-wrapper">
        <img src="<%= product.imageUrl %>" alt="<%= product.name %>" id="product-detail-main-image">
      </div>
    </div>
    
    <!-- Specs Column -->
    <div class="detail-specs">
      <span class="specs-category capitalize-text"><%= product.category %></span>
      <h1><%= product.name %></h1>
      
      <!-- Price and Status -->
      <div class="price-status-row">
        <span class="specs-price" id="specs-display-price" data-base-price="<%= product.price %>">$<%= product.price.toFixed(2) %></span>
        
        <% if (product.stockStatus === 'in-stock') { %>
          <span class="status-badge instock"><i class="fa-solid fa-circle-check"></i> Freshly Packed (In Stock)</span>
        <% } else if (product.stockStatus === 'low-stock') { %>
          <span class="status-badge lowstock"><i class="fa-solid fa-circle-exclamation"></i> Only A Few Left (Low Stock)</span>
        <% } else { %>
          <span class="status-badge outofstock"><i class="fa-solid fa-ban"></i> Out of Stock</span>
        <% } %>
      </div>
      
      <p class="specs-description"><%= product.description %></p>
      
      <!-- Available Sizes Listing -->
      <% if (product.sizes && product.sizes.length > 0) { %>
        <div class="pantry-sizes-listing">
          <span class="sizes-label">Available Packaging Sizes</span>
          <div class="sizes-container">
            <% product.sizes.forEach((size) => { %>
              <span class="size-pill"><%= size %></span>
            <% }) %>
          </div>
        </div>
      <% if (product.stockStatus === 'out-of-stock') { %>
        <div class="out-of-stock-alert">
          <h4>Sold Out</h4>
          <p>We are currently grinding a fresh batch of this spice. Enter your email below to get notified when it returns.</p>
          <div class="form-input-group">
            <input type="email" placeholder="Your email address" aria-label="Waitlist email">
            <button class="btn btn-secondary" onclick="alert('You have been added to the waitlist!');">Notify Me</button>
          </div>
        </div>
      <% } %>

      <!-- Accordion Specifications -->
      <div class="product-accordion">
        
        <% if (product.ingredients) { %>
          <div class="accordion-item active">
            <button class="accordion-trigger" onclick="toggleAccordion(this)">
              <span>Ingredients</span> <i class="fa-solid fa-chevron-down"></i>
            </button>
            <div class="accordion-panel">
              <p><%= product.ingredients %></p>
            </div>
          </div>
        <% } %>
        
        <div class="accordion-item">
          <button class="accordion-trigger" onclick="toggleAccordion(this)">
            <span>Culinary Use & Storage Tips</span> <i class="fa-solid fa-chevron-down"></i>
          </button>
          <div class="accordion-panel">
            <p>Store in a cool, dry, dark pantry away from direct heat and moisture. Toast whole spices for 60-90 seconds in a dry pan before grinding to activate essential oils.</p>
          </div>
        </div>
        
        <div class="accordion-item">
          <button class="accordion-trigger" onclick="toggleAccordion(this)">
            <span>Packaging & Shipping</span> <i class="fa-solid fa-chevron-down"></i>
          </button>
          <div class="accordion-panel">
            <p>Shipped in double-sealed premium food-grade packages. Glass jars are bubble-wrapped and packaged in post-consumer recycled boxes. We ship ground orders within 24 hours of packing.</p>
          </div>
        </div>

      </div>

    </div>
  </div>
</section>

<!-- Related Products section -->
<section class="related-products-section container">
  <div class="section-header">
    <h2>Complete Your Pantry</h2>
    <p>Other essential spices you might need in your spice drawer</p>
  </div>
  
  <div class="products-grid">
    <% if (relatedProducts && relatedProducts.length > 0) { %>
      <% relatedProducts.forEach(prod => { %>
        <div class="product-card">
          <div class="product-card-image">
            <a href="/products/<%= prod.slug %>">
              <img src="<%= prod.imageUrl %>" alt="<%= prod.name %>" loading="lazy">
            </a>
            <span class="product-category-tag"><%= prod.category %></span>
          </div>
          
          <div class="product-card-info">
            <h3><a href="/products/<%= prod.slug %>"><%= prod.name %></a></h3>
            <p class="product-excerpt"><%= prod.description.substring(0, 80) %>...</p>
            <div class="product-card-footer">
              <span class="product-price">$<%= prod.price.toFixed(2) %></span>
              <a href="/products/<%= prod.slug %>" class="btn btn-secondary btn-sm">Details</a>
            </div>
          </div>
        </div>
      <% }) %>
    <% } else { %>
      <p class="no-items">Browse more spices on our Shop page!</p>
    <% } %>
  </div>
</section>

<script>
  function toggleAccordion(button) {
    const item = button.parentElement;
    item.classList.toggle('active');
  }
</script>

<%- include('partials/footer') %>
