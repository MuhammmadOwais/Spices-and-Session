<%- include('partials/header') %>

<!-- Breadcrumbs navigation -->
<div class="breadcrumbs-nav container">
  <a href="/">Home</a>
  <span class="separator"><i class="fa-solid fa-chevron-right"></i></span>
  <a href="/products">Shop</a>
  <span class="separator"><i class="fa-solid fa-chevron-right"></i></span>
  <a href="/products?category=<%= product.category %>" class="capitalize-text"><%= product.category %></a>
  <span class="separator"><i class="fa-solid fa-chevron-right"></i></span>
  <span class="current"><%= product.name %></span>
</div>

<!-- Product Detail Showcase -->
<section class="product-detail-showcase container">
  <div class="detail-layout">
    
    <!-- Gallery Column -->
    <div class="detail-gallery">
      <div class="main-image-wrapper">
        <img src="<%= product.imageUrl %>" alt="<%= product.name %>" id="product-detail-main-image">
      </div>
    </div>
    
    <!-- Specs Column -->
    <div class="detail-specs">
      <span class="specs-category capitalize-text"><%= product.category %></span>
      <h1><%= product.name %></h1>
      
      <!-- Price and Status -->
      <div class="price-status-row">
        <span class="specs-price" id="specs-display-price" data-base-price="<%= product.price %>">$<%= product.price.toFixed(2) %></span>
        
        <% if (product.stockStatus === 'in-stock') { %>
          <span class="status-badge instock"><i class="fa-solid fa-circle-check"></i> Freshly Packed (In Stock)</span>
        <% } else if (product.stockStatus === 'low-stock') { %>
          <span class="status-badge lowstock"><i class="fa-solid fa-circle-exclamation"></i> Only A Few Left (Low Stock)</span>
        <% } else { %>
          <span class="status-badge outofstock"><i class="fa-solid fa-ban"></i> Out of Stock</span>
        <% } %>
      </div>
      
      <p class="specs-description"><%= product.description %></p>
      
      <!-- Available Sizes Listing -->
      <% if (product.sizes && product.sizes.length > 0) { %>
        <div class="pantry-sizes-listing">
          <span class="sizes-label">Available Packaging Sizes</span>
          <div class="sizes-container">
            <% product.sizes.forEach((size) => { %>
              <span class="size-pill"><%= size %></span>
            <% }) %>
          </div>
        </div>
      <% if (product.stockStatus === 'out-of-stock') { %>
        <div class="out-of-stock-alert">
          <h4>Sold Out</h4>
          <p>We are currently grinding a fresh batch of this spice. Enter your email below to get notified when it returns.</p>
          <div class="form-input-group">
            <input type="email" placeholder="Your email address" aria-label="Waitlist email">
            <button class="btn btn-secondary" onclick="alert('You have been added to the waitlist!');">Notify Me</button>
          </div>
        </div>
      <% } %>

      <!-- Accordion Specifications -->
      <div class="product-accordion">
        
        <% if (product.ingredients) { %>
          <div class="accordion-item active">
            <button class="accordion-trigger" onclick="toggleAccordion(this)">
              <span>Ingredients</span> <i class="fa-solid fa-chevron-down"></i>
            </button>
            <div class="accordion-panel">
              <p><%= product.ingredients %></p>
            </div>
          </div>
        <% } %>
        
        <div class="accordion-item">
          <button class="accordion-trigger" onclick="toggleAccordion(this)">
            <span>Culinary Use & Storage Tips</span> <i class="fa-solid fa-chevron-down"></i>
          </button>
          <div class="accordion-panel">
            <p>Store in a cool, dry, dark pantry away from direct heat and moisture. Toast whole spices for 60-90 seconds in a dry pan before grinding to activate essential oils.</p>
          </div>
        </div>
        
        <div class="accordion-item">
          <button class="accordion-trigger" onclick="toggleAccordion(this)">
            <span>Packaging & Shipping</span> <i class="fa-solid fa-chevron-down"></i>
          </button>
          <div class="accordion-panel">
            <p>Shipped in double-sealed premium food-grade packages. Glass jars are bubble-wrapped and packaged in post-consumer recycled boxes. We ship ground orders within 24 hours of packing.</p>
          </div>
        </div>

      </div>

    </div>
  </div>
</section>

<%
  // Ingredient dictionary
  const ingredientDictionary = {
    "paprika": {
      name: "Smoked Paprika",
      symbol: "Pa",
      imageUrl: "https://res.cloudinary.com/dawp1fcci/image/upload/f_auto,q_auto/v1784235729/pexels-taryn-elliott-5107126_dh7afi.jpg",
      description: "Oak-smoked Spanish sweet pimentón that adds a warm color and mild sweetness."
    },
    "garlic": {
      name: "Granulated Garlic",
      symbol: "Ga",
      imageUrl: "https://res.cloudinary.com/dawp1fcci/image/upload/f_auto,q_auto/v1784235731/pexels-roman-odintsov-5332494_tyurxa.jpg",
      description: "Adds a strong, pungent, spicy, and slightly sweet flavor layer."
    },
    "cinnamon": {
      name: "Korintje Cinnamon",
      symbol: "Ci",
      imageUrl: "https://res.cloudinary.com/dawp1fcci/image/upload/f_auto,q_auto/v1784235732/pexels-ruslan-rozanov-174297693-11733646_cyx9bi.jpg",
      description: "Intensely sweet and warm spice harvested from Sumatran volcanic slopes."
    },
    "salt": {
      name: "Sea Salt Flakes",
      symbol: "Sa",
      imageUrl: "https://res.cloudinary.com/dawp1fcci/image/upload/f_auto,q_auto/v1784235732/pexels-karola-g-4871142_jsbzj0.jpg",
      description: "Pure, mineral-rich salt crystals that elevate all surrounding flavor notes."
    },
    "turmeric": {
      name: "Golden Turmeric Root",
      symbol: "Tu",
      imageUrl: "https://res.cloudinary.com/dawp1fcci/image/upload/f_auto,q_auto/v1784235730/pexels-caricatte-6245955_jbyi4j.jpg",
      description: "Earthy, warm, and bright golden root powder packed with active curcumin."
    },
    "cumin": {
      name: "Roasted Cumin",
      symbol: "Cu",
      imageUrl: "https://res.cloudinary.com/dawp1fcci/image/upload/f_auto,q_auto/v1784235729/pexels-taryn-elliott-5107126_dh7afi.jpg",
      description: "Warm, earthy, and aromatic seed powder with light citrus highlights."
    },
    "pepper": {
      name: "Tellicherry Peppercorns",
      symbol: "Pe",
      imageUrl: "https://res.cloudinary.com/dawp1fcci/image/upload/f_auto,q_auto/v1784235732/pexels-ruslan-rozanov-174297693-11733646_cyx9bi.jpg",
      description: "Pungent, woodsy, and bright spice with citrus notes."
    },
    "sesame": {
      name: "Sesame Seeds",
      symbol: "Se",
      imageUrl: "https://res.cloudinary.com/dawp1fcci/image/upload/f_auto,q_auto/v1784235732/pexels-kostiantyn-35496287_qprzhx.jpg",
      description: "Nutty, toasted sesame seeds that add texture and a rich crunch."
    },
    "onion": {
      name: "Minced Onion",
      symbol: "On",
      imageUrl: "https://res.cloudinary.com/dawp1fcci/image/upload/f_auto,q_auto/v1784235731/pexels-roman-odintsov-5332494_tyurxa.jpg",
      description: "Adds sweet, savory, and caramelized elements to seasoning profiles."
    },
    "rosemary": {
      name: "Dried Rosemary",
      symbol: "Ro",
      imageUrl: "https://res.cloudinary.com/dawp1fcci/image/upload/f_auto,q_auto/v1784235731/pexels-julia-fuchs-19936537-33966639_qxcnes.jpg",
      description: "Piney, aromatic herb that gives a deep green botanical fragrance."
    },
    "thyme": {
      name: "Summer Thyme",
      symbol: "Th",
      imageUrl: "https://res.cloudinary.com/dawp1fcci/image/upload/f_auto,q_auto/v1784235731/pexels-julia-fuchs-19936537-33966639_qxcnes.jpg",
      description: "Subtle earthy herb with light notes of grass, wood, and floral tones."
    },
    "oregano": {
      name: "Wild Oregano",
      symbol: "Or",
      imageUrl: "https://res.cloudinary.com/dawp1fcci/image/upload/f_auto,q_auto/v1784235731/pexels-julia-fuchs-19936537-33966639_qxcnes.jpg",
      description: "Pungent herb that delivers traditional rustic Mediterranean flavors."
    },
    "basil": {
      name: "Sweet Basil",
      symbol: "Ba",
      imageUrl: "https://res.cloudinary.com/dawp1fcci/image/upload/f_auto,q_auto/v1784235731/pexels-julia-fuchs-19936537-33966639_qxcnes.jpg",
      description: "Peppery and sweet herb with a fresh, anise-like flavor profile."
    },
    "lavender": {
      name: "Lavender Buds",
      symbol: "Lv",
      imageUrl: "https://res.cloudinary.com/dawp1fcci/image/upload/f_auto,q_auto/v1784235731/pexels-julia-fuchs-19936537-33966639_qxcnes.jpg",
      description: "Fragrant, sweet, and floral buds that add a sensory French highlight."
    },
    "pineapple": {
      name: "Pineapple Powder",
      symbol: "Pi",
      imageUrl: "https://res.cloudinary.com/dawp1fcci/image/upload/f_auto,q_auto/v1784235730/pexels-caricatte-6245955_jbyi4j.jpg",
      description: "Real sweet and tart pineapple in powder form - adds a tropical layer."
    }
  };

  // Find matches based on product.ingredients string
  const resolvedIngredients = [];
  if (product.ingredients) {
    const rawIngs = product.ingredients.toLowerCase();
    Object.keys(ingredientDictionary).forEach(key => {
      if (rawIngs.includes(key)) {
        resolvedIngredients.push(ingredientDictionary[key]);
      }
    });
  }

  // Fallback if no ingredients resolved
  if (resolvedIngredients.length === 0) {
    // Populate some default elements based on category
    if (product.category === 'spices') {
      resolvedIngredients.push(ingredientDictionary["paprika"]);
      resolvedIngredients.push(ingredientDictionary["cumin"]);
      resolvedIngredients.push(ingredientDictionary["pepper"]);
    } else if (product.category === 'herbs') {
      resolvedIngredients.push(ingredientDictionary["rosemary"]);
      resolvedIngredients.push(ingredientDictionary["thyme"]);
      resolvedIngredients.push(ingredientDictionary["oregano"]);
    } else {
      resolvedIngredients.push(ingredientDictionary["salt"]);
      resolvedIngredients.push(ingredientDictionary["garlic"]);
      resolvedIngredients.push(ingredientDictionary["onion"]);
    }
  }
%>

<!-- Deconstructed Flavor Profile -->
<section class="deconstructed-section container">
  <h2 class="deconstructed-title">Deconstructed Flavor Profile</h2>
  <p class="deconstructed-subtitle">A visual breakdown of the raw materials inside this premium blend</p>
  
  <div class="deconstructed-grid">
    <% resolvedIngredients.forEach((ing, idx) => { %>
      <% if (idx > 0) { %>
        <div class="deconstructed-plus">+</div>
      <% } %>
      <div class="deconstructed-item">
        <div class="deconstructed-img-wrapper">
          <img src="<%= ing.imageUrl %>" alt="<%= ing.name %>">
        </div>
        <hr class="deconstructed-item-divider">
        <div class="deconstructed-item-title-row">
          <span class="deconstructed-symbol"><%= ing.symbol %></span>
          <h3><%= ing.name %></h3>
        </div>
        <p><%= ing.description %></p>
      </div>
    <% }) %>
  </div>
</section>

<!-- Related Products section -->
<section class="related-products-section container">
  <div class="section-header">
    <h2>Complete Your Pantry</h2>
    <p>Other essential spices you might need in your spice drawer</p>
  </div>
  
  <div class="products-grid">
    <% if (relatedProducts && relatedProducts.length > 0) { %>
      <% relatedProducts.forEach(prod => { %>
        <div class="product-card">
          <div class="product-card-image">
            <a href="/products/<%= prod.slug %>">
              <img src="<%= prod.imageUrl %>" alt="<%= prod.name %>" loading="lazy">
            </a>
            <span class="product-category-tag"><%= prod.category %></span>
          </div>
          
          <div class="product-card-info">
            <h3><a href="/products/<%= prod.slug %>"><%= prod.name %></a></h3>
            <p class="product-excerpt"><%= prod.description.substring(0, 80) %>...</p>
            <div class="product-card-footer">
              <span class="product-price">$<%= prod.price.toFixed(2) %></span>
              <a href="/products/<%= prod.slug %>" class="btn btn-secondary btn-sm">Details</a>
            </div>
          </div>
        </div>
      <% }) %>
    <% } else { %>
      <p class="no-items">Browse more spices on our Shop page!</p>
    <% } %>
  </div>
</section>

<script>
  function toggleAccordion(button) {
    const item = button.parentElement;
    item.classList.toggle('active');
  }
</script>

<%- include('partials/footer') %>
