<%- include('../partials/header') %>

<section class="admin-crud-section container">
  
  <div class="admin-header-row">
    <div>
      <a href="/admin" class="back-link"><i class="fa-solid fa-arrow-left"></i> Back to Dashboard</a>
      <h1>Product Inventory</h1>
      <p>Configure pricing, sizes, description details, and upload primary spice imagery.</p>
    </div>
    <div>
      <a href="/admin/products/new" class="btn btn-primary"><i class="fa-solid fa-plus"></i> Add New Product</a>
    </div>
  </div>

  <div class="crud-table-wrapper">
    <% if (products && products.length > 0) { %>
      <table class="crud-data-table">
        <thead>
          <tr>
            <th>Image</th>
            <th>Spice Name</th>
            <th>Category</th>
            <th>Price</th>
            <th>Sizes</th>
            <th>Stock Status</th>
            <th class="text-right">Actions</th>
          </tr>
        </thead>
        <tbody>
          <% products.forEach(product => { %>
            <tr>
              <td>
                <img src="<%= product.imageUrl %>" alt="<%= product.name %>" class="table-thumbnail-img">
              </td>
              <td>
                <strong><%= product.name %></strong>
                <% if (product.isFeatured) { %>
                  <span class="badge badge-accent-light">Featured</span>
                <% } %>
              </td>
              <td class="capitalize-text"><%= product.category %></td>
              <td>$<%= product.price.toFixed(2) %></td>
              <td>
                <span class="table-small-text"><%= product.sizes.join(', ') %></span>
              </td>
              <td>
                <% if (product.stockStatus === 'in-stock') { %>
                  <span class="badge badge-success">In Stock</span>
                <% } else if (product.stockStatus === 'low-stock') { %>
                  <span class="badge badge-warning">Low Stock</span>
                <% } else { %>
                  <span class="badge badge-danger">Out of Stock</span>
                <% } %>
              </td>
              <td class="text-right table-actions-cell">
                <a href="/admin/products/<%= product._id %>/edit" class="btn-action btn-edit-icon" title="Edit Product"><i class="fa-solid fa-pen-to-square"></i></a>
                
                <form action="/admin/products/<%= product._id %>/delete" method="POST" class="inline-form" onsubmit="return confirm('Are you sure you want to permanently delete this product? This action is irreversible.');">
                  <button type="submit" class="btn-action btn-delete-icon" title="Delete Product"><i class="fa-solid fa-trash-can"></i></button>
                </form>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    <% } else { %>
      <div class="empty-crud-state text-center">
        <i class="fa-solid fa-box-open"></i>
        <h3>No Products Found</h3>
        <p>Start adding premium spice blends to your inventory catalog.</p>
        <a href="/admin/products/new" class="btn btn-primary">Create Your First Product</a>
      </div>
    <% } %>
  </div>

</section>

<%- include('../partials/footer') %>
