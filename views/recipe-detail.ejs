<%- include('partials/header') %>

<!-- Custom modular styling for the Recipe Details page -->
<style>
  .recipe-detail-hero {
    position: relative;
    padding: 10rem 2rem 6rem;
    background-size: cover;
    background-position: center;
    color: #ffffff;
  }
  .recipe-detail-hero::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(rgba(0, 0, 0, 0.45), rgba(0, 0, 0, 0.85));
    z-index: 1;
  }
  .recipe-hero-container {
    position: relative;
    z-index: 2;
    max-width: 850px;
    margin: 0 auto;
  }
  .recipe-detail-method {
    display: inline-block;
    background-color: var(--color-accent-terracotta);
    color: #000000;
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    padding: 0.4rem 1rem;
    border-radius: 3px;
    margin-bottom: 1.5rem;
  }
  .recipe-hero-container h1 {
    font-family: var(--font-serif);
    font-size: 3.5rem;
    font-weight: 800;
    margin-bottom: 1rem;
    line-height: 1.25;
    letter-spacing: -0.01em;
  }
  .recipe-detail-subtitle {
    font-size: 1.25rem;
    color: #e0e0e0;
    line-height: 1.5;
    margin-bottom: 2.2rem;
  }
  .recipe-detail-meta {
    display: flex;
    gap: 2.5rem;
    flex-wrap: wrap;
    border-top: 1px solid rgba(255, 255, 255, 0.15);
    padding-top: 1.5rem;
  }
  .recipe-meta-item {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    font-size: 0.85rem;
    text-transform: uppercase;
    font-weight: 600;
    letter-spacing: 0.05em;
    color: #e0e0e0;
  }
  .recipe-meta-item i {
    color: var(--color-accent-terracotta);
    font-size: 1.1rem;
  }

  .recipe-detail-content {
    padding: 6rem 0;
    background-color: #ffffff;
  }
  .recipe-content-grid {
    display: grid;
    grid-template-columns: 0.8fr 1.2fr;
    gap: 5rem;
    align-items: start;
  }
  
  .ingredients-wrapper {
    background-color: var(--color-bg-warm-gray);
    border: 1px solid var(--color-border);
    border-radius: var(--border-radius-large);
    padding: 2.5rem;
    box-shadow: var(--box-shadow-soft);
  }
  .ingredients-wrapper h2 {
    font-family: var(--font-serif);
    font-size: 1.8rem;
    font-weight: 800;
    margin-bottom: 1.5rem;
    color: var(--color-primary);
  }
  .ingredients-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .ingredients-list li {
    display: flex;
    align-items: flex-start;
    gap: 0.8rem;
    font-size: 0.95rem;
    color: var(--color-secondary);
    line-height: 1.4;
  }
  .ingredients-list li i {
    color: var(--color-accent-terracotta);
    margin-top: 0.25rem;
    font-size: 0.85rem;
  }

  .instructions-wrapper h2 {
    font-family: var(--font-serif);
    font-size: 2rem;
    font-weight: 800;
    margin-bottom: 1.8rem;
    color: var(--color-primary);
  }
  .instructions-content {
    font-size: 1.05rem;
    line-height: 1.8;
    color: #444444;
  }
  .instructions-content p {
    margin-bottom: 1.5rem;
  }
  .instructions-content ol, .instructions-content ul {
    margin: 1.5rem 0;
    padding-left: 1.5rem;
  }
  .instructions-content li {
    margin-bottom: 1rem;
  }

  .recipe-footer-nav {
    border-top: 1px solid var(--color-border);
    padding-top: 2rem;
    margin-top: 4rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  @media (max-width: 992px) {
    .recipe-content-grid {
      grid-template-columns: 1fr;
      gap: 4rem;
    }
    .recipe-hero-container h1 {
      font-size: 2.5rem;
    }
  }
</style>

<!-- Recipe Detail Hero -->
<section class="recipe-detail-hero" style="background-image: url('<%= recipe.imageUrl %>');">
  <div class="recipe-hero-container">
    <span class="recipe-detail-method"><%= recipe.method %> Masterclass</span>
    <h1><%= recipe.title %></h1>
    <p class="recipe-detail-subtitle"><%= recipe.subtitle %></p>
    
    <div class="recipe-detail-meta">
      <div class="recipe-meta-item">
        <i class="fa-solid fa-circle-user"></i>
        <span>By <%= recipe.author %></span>
      </div>
      <div class="recipe-meta-item">
        <i class="fa-solid fa-gauge-simple-high"></i>
        <span><%= recipe.difficulty %></span>
      </div>
      <div class="recipe-meta-item">
        <i class="fa-solid fa-clock"></i>
        <span>Prep: <%= recipe.prepTime %> Mins</span>
      </div>
      <div class="recipe-meta-item">
        <i class="fa-solid fa-fire-burner"></i>
        <span>Cook: <%= recipe.cookTime %> Mins</span>
      </div>
      <div class="recipe-meta-item">
        <i class="fa-solid fa-utensils"></i>
        <span><%= recipe.servings %> Servings</span>
      </div>
    </div>
  </div>
</section>

<!-- Recipe Content Row -->
<section class="recipe-detail-content">
  <div class="container recipe-content-grid">
    
    <!-- Left Column: Ingredients -->
    <div class="ingredients-wrapper">
      <h2>Ingredients</h2>
      <ul class="ingredients-list">
        <% recipe.ingredients.split(',').forEach((ingredient) => { %>
          <li>
            <i class="fa-solid fa-circle-check"></i>
            <span><%= ingredient.trim() %></span>
          </li>
        <% }) %>
      </ul>
    </div>
    
    <!-- Right Column: Step Instructions -->
    <div class="instructions-wrapper">
      <h2>Method Instructions</h2>
      <div class="instructions-content">
        <%- recipe.instructions %>
      </div>
      
      <!-- Back Button Row -->
      <div class="recipe-footer-nav">
        <a href="/recipes" class="btn btn-secondary"><i class="fa-solid fa-arrow-left"></i> Back to Recipes</a>
      </div>
    </div>

  </div>
</section>

<%- include('partials/footer') %>
