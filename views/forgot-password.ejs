<%- include('partials/header') %>

<style>
  .auth-section {
    padding: 8rem 0;
    background-color: var(--color-bg-warm-gray);
    min-height: 80vh;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .auth-card {
    background-color: #ffffff;
    border: 1px solid var(--color-border);
    border-radius: var(--border-radius-large);
    padding: 3rem;
    width: 100%;
    max-width: 480px;
    box-shadow: var(--box-shadow-medium);
  }
  .auth-card h2 {
    font-family: var(--font-serif);
    font-size: 2.2rem;
    font-weight: 800;
    margin-bottom: 0.8rem;
    color: var(--color-primary);
    text-align: center;
  }
  .auth-card p.auth-subtitle {
    text-align: center;
    color: #666666;
    font-size: 0.95rem;
    margin-bottom: 2rem;
    line-height: 1.4;
  }
  .auth-form-group {
    margin-bottom: 1.5rem;
  }
  .auth-form-group label {
    display: block;
    font-size: 0.8rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-primary);
    margin-bottom: 0.5rem;
  }
  .auth-form-group input {
    width: 100%;
    padding: 0.75rem 1rem;
    border: 1px solid var(--color-border);
    border-radius: var(--border-radius);
    outline: none;
    font-size: 0.95rem;
    font-family: var(--font-sans);
    transition: var(--transition-fast);
  }
  .auth-form-group input:focus {
    border-color: var(--color-accent-terracotta);
    box-shadow: 0 0 0 3px rgba(255, 204, 0, 0.15);
  }
  .auth-alert-error {
    background-color: #fdf2f2;
    border: 1px solid #f8b4b4;
    color: #9b1c1c;
    padding: 1rem;
    border-radius: var(--border-radius);
    font-size: 0.88rem;
    margin-bottom: 1.8rem;
    display: flex;
    align-items: center;
    gap: 0.6rem;
  }
  .auth-alert-success {
    background-color: #f3faf5;
    border: 1px solid #def7ec;
    color: #03543f;
    padding: 1.2rem;
    border-radius: var(--border-radius);
    font-size: 0.92rem;
    margin-bottom: 1.8rem;
    line-height: 1.5;
  }
  .auth-submit-btn {
    width: 100%;
    background-color: var(--color-primary);
    color: #ffffff;
    border: none;
    padding: 0.85rem;
    font-weight: 700;
    text-transform: uppercase;
    font-size: 0.85rem;
    letter-spacing: 0.08em;
    border-radius: var(--border-radius);
    transition: var(--transition-smooth);
    margin-top: 1rem;
  }
  .auth-submit-btn:hover {
    background-color: var(--color-accent-terracotta);
    color: #000000;
    transform: translateY(-2px);
  }
  .auth-switch-prompt {
    text-align: center;
    margin-top: 1.8rem;
    font-size: 0.88rem;
    color: #666666;
  }
  .auth-switch-prompt a {
    color: var(--color-primary);
    font-weight: 700;
    text-decoration: underline;
  }
  .auth-switch-prompt a:hover {
    color: var(--color-accent-terracotta);
  }
</style>

<section class="auth-section">
  <div class="auth-card">
    <h2>Reset Password</h2>
    <p class="auth-subtitle">Enter your email address and we will update your password in our database</p>
    
    <% if (error) { %>
      <div class="auth-alert-error">
        <i class="fa-solid fa-circle-exclamation"></i>
        <span><%= error %></span>
      </div>
    <% } %>

    <% if (success) { %>
      <div class="auth-alert-success">
        <i class="fa-solid fa-circle-check"></i>
        <span><%- success %></span>
      </div>
    <% } %>
    
    <form action="/forgot-password" method="POST">
      <div class="auth-form-group">
        <label for="email-field">Email Address</label>
        <input type="email" id="email-field" name="email" placeholder="you@example.com" required autocomplete="email">
      </div>
      
      <button type="submit" class="auth-submit-btn">Reset Password</button>
    </form>
    
    <div class="auth-switch-prompt">
      Remembered your password? <a href="/login">Sign In</a>
    </div>
  </div>
</section>

<%- include('partials/footer') %>
