<%- include('partials/header') %>

<section class="checkout-success-section container">
  <div class="success-card text-center">
    <div class="success-icon"><i class="fa-solid fa-circle-check"></i></div>
    <h1>Thank You For Your Order!</h1>
    <p class="success-tagline">Your culinary kit is being ground and packed by hand.</p>
    
    <div class="order-details-box">
      <h3>Order Confirmation Details</h3>
      <hr class="summary-divider">
      <div class="detail-row">
        <span>Customer Name:</span>
        <strong><%= orderInfo.name %></strong>
      </div>
      <div class="detail-row">
        <span>Confirmation Email:</span>
        <strong><%= orderInfo.email %></strong>
      </div>
      <div class="detail-row">
        <span>Delivery Address:</span>
        <strong><%= orderInfo.address %>, <%= orderInfo.city %>, <%= orderInfo.zip %></strong>
      </div>
      <div class="detail-row">
        <span>Estimated Delivery:</span>
        <strong>3 - 5 Business Days</strong>
      </div>
    </div>
    
    <p class="success-support-note">We have sent a confirmation email to <strong><%= orderInfo.email %></strong> with tracking details. If you have any questions, reach out to our team at <code>support@artisanspice.com</code>.</p>
    
    <div class="success-actions">
      <a href="/products" class="btn btn-primary">Return to Marketplace</a>
      <a href="/" class="btn btn-secondary">Go to Homepage</a>
    </div>
  </div>
</section>

<!-- Script to clear cart on successful checkout -->
<script>
  document.addEventListener('DOMContentLoaded', () => {
    // If the cart system is loaded, clear all items
    if (typeof cartManager !== 'undefined') {
      cartManager.clearCart();
    } else {
      localStorage.removeItem('artisan_cart');
    }
  });
</script>

<%- include('partials/footer') %>
